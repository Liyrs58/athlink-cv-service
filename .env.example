# ==================== REQUIRED ====================
# Core API credentials and keys

# Anthropic Claude API key (for tactical analysis, interpretation, conversation)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key (for match analysis)
GEMINI_API_KEY=

# Roboflow API key (for football ball detection model management)
ROBOFLOW_API_KEY=

# ==================== OPTIONAL: STORAGE ====================
# Supabase cloud storage (for uploading analysis results)

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (public)
SUPABASE_KEY=

# Supabase service role key (private, for uploads)
SUPABASE_SERVICE_ROLE_KEY=

# ==================== OPTIONAL: DISTRIBUTED GPU ====================
# RunPod for parallel GPU processing

# RunPod API key
RUNPOD_API_KEY=

# RunPod serverless endpoint ID
RUNPOD_ENDPOINT_ID=

# ==================== OPTIONAL: DEPLOYMENT ====================
# Server configuration

# Port to bind server to (default: 8001)
PORT=8001

# ==================== OPTIONAL: YOLO DETECTION ====================
# Computer vision model configuration

# Path to YOLOv11 football-specific model (default: yolov8n.pt)
YOLO_MODEL_PATH=yolov8n.pt

# Path to ball detection model, e.g., ball.pt or yolov8s.pt (default: ball.pt)
BALL_MODEL_PATH=ball.pt

# YOLO detection confidence threshold (0.0-1.0, default: 0.35)
YOLO_CONF=0.35

# YOLO IoU (Intersection over Union) threshold for NMS (default: 0.45)
YOLO_IOU=0.45

# YOLO device: 'cpu' or 'cuda' (default: auto-detect)
YOLO_DEVICE=cpu

# Frame sampling rate for tracking pipeline (default: 3, means process every 3rd frame)
TRACKING_SAMPLE_RATE=3

# ==================== OPTIONAL: FRAME PROCESSING ====================
# Video frame analysis settings

# Dark frame detection threshold (0-255, default: 20.0)
# Frames with avg brightness < threshold are skipped
FRAME_DARK_THRESHOLD=20.0

# Skip rendering annotated video output
SKIP_ANNOTATED_VIDEO=false

# ==================== OPTIONAL: 3D REPLAY RENDERING ====================
# Remotion + OpenGL settings

# Enable WebGL rendering for 3D replays (default: false)
REPLAY3D_GL=false

# ==================== OPTIONAL: ADVANCED ====================
# Expert settings (do not change unless you know what you're doing)

# Directory for pitch corner calibration models
PNLCALIB_DIR=./models/pnlcalib

# Weights directory for pitch corner calibration
PNLCALIB_WEIGHTS_DIR=./models/pnlcalib/weights

# Directory for async job queue and outputs
JOBS_DIR=./temp
